# API Configuration
# Change this to point to your API server
VITE_API_URL=http://localhost:7208

# Database Configuration
POSTGRES_DB=personal_finance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ── AI Service keys ───────────────────────────────────────────────
# Read ONLY by Docker Compose, which injects this into the ai-service
# container (docker-compose.yml: GEMINI_API_KEY=${GEMINI_API_KEY:-};
# same applies to AI_PROVIDER / ANTHROPIC_API_KEY / AI_MODEL).
#
# Running the AI service locally with `uvicorn`? This file is IGNORED —
# the service reads services/ai-service/.env exclusively (path is
# hard-coded in services/ai-service/app/config.py). Put your key there.
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (backend — server-side operations)
Supabase__Url=https://your-project-ref.supabase.co
Supabase__AnonKey=your-anon-key-here
Supabase__ServiceRoleKey=your-service-role-key-here
