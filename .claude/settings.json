{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Edit(**)",
      "Edit(/**)",
      "Write(*)",
      "Write(**)",
      "Write(/**)",
      "Read(*)",
      "Read(**)",
      "Read(/**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__playwright__*",
      "mcp__filesystem__*",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm *)",
      "Bash(dotnet ef database drop*)"
    ],
    "additionalDirectories": [
      "c:\\workspaces\\personal-finance\\.claude\\plans",
      "c:\\workspaces\\personal-finance\\.claude\\skills"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/push-notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py c:/workspaces/personal-finance/.claude/hooks/plan-complete-sync.py"
          }
        ]
      }
    ]
  }
}
