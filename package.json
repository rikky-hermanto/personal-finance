{
  "name": "personal-finance",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prestart": "powershell -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 7208 -ErrorAction SilentlyContinue).OwningProcess -Force -ErrorAction SilentlyContinue\" || exit 0",
    "start": "(docker start personalfinance-db || docker compose up -d db) && concurrently --kill-others-on-fail --names \"api,ui\" --prefix-colors \"yellow,cyan\" \"cd apps/api && dotnet run --project src/PersonalFinance.Api\" \"cd apps/frontend && npm run dev\"",
    "dev": "cd apps/frontend && npm run dev",
    "build": "cd apps/frontend && npm run build",
    "lint": "cd apps/frontend && npm run lint",
    "e2e": "cd apps/frontend && npx playwright test",
    "e2e:ui": "cd apps/frontend && npx playwright test --ui"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
