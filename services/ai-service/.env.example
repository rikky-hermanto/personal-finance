# ══════════════════════════════════════════════════════════════════
# AI Service environment — services/ai-service/.env
#
# THIS is the AI service's env file. Running locally with `uvicorn`,
# app/config.py reads THIS file exclusively (the path is hard-coded) and
# never the repo-root .env. Set your keys here for local dev.
#
# In Docker Compose the root .env supplies these vars instead, injected
# per docker-compose.yml. If you run both ways, keep the two in sync.
# ══════════════════════════════════════════════════════════════════

# Active provider: gemini | anthropic
AI_PROVIDER=gemini

# Gemini (default — get key at aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here
AI_MODEL=gemini-2.5-flash

# Anthropic (set AI_PROVIDER=anthropic to use)
# ANTHROPIC_API_KEY=your-anthropic-key-here
# AI_MODEL=claude-sonnet-4-6

LOG_LEVEL=INFO

#AI Obserability
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST="https://cloud.langfuse.com"
LANGFUSE_BASE_URL="https://cloud.langfuse.com"